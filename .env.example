# Polymarket Live Trading Configuration
# For Live Trading: Only PRIVATE_KEY and PROXY_ADDRESS are required
# API credentials are automatically derived from the private key using L1→L2 auth

# Your Ethereum private key (format: without "0x" prefix)
PRIVATE_KEY=your_private_key_here

# Your Polymarket proxy wallet address on Polygon
PROXY_ADDRESS=your_proxy_wallet_address_here

# Market Configuration (update in config/variables.go)
# Add your market IDs and configuration there

# Trading Mode
PAPER_TRADING_ENABLED=false

# Polling Interval (milliseconds)
MARKET_FETCH_INTERVAL_MS=5000

